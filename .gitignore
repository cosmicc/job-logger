# Python bytecode and local caches are generated by the interpreter and tests.
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Virtual environments must stay local to the workstation or container.
.venv/
venv/

# Environment files contain deployment-specific secrets and must not be committed.
.env
.env.*
!.env.example

# Local database, upload, and runtime artifacts must not enter source control.
*.sqlite3
*.db
data/
uploads/
tmp/

# Docker and editor output.
*.log
.DS_Store
.idea/
.vscode/

