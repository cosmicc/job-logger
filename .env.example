# Copy this file to .env and replace every production secret before deployment.

# Docker PostgreSQL settings.
POSTGRES_DB=job_logger
POSTGRES_USER=job_logger
POSTGRES_PASSWORD=replace-with-a-long-random-database-password

# FastAPI application settings.
APP_ENV=production
APP_SECRET_KEY=replace-with-at-least-32-random-characters
APP_USERNAME=admin
APP_PASSWORD_HASH=replace-with-an-argon2id-password-hash
APP_PASSWORD=
APP_SESSION_COOKIE_SECURE=true
APP_ALLOWED_HOSTS=localhost,127.0.0.1,app,replace-with-your-cloudflare-public-hostname
APP_EXPOSE_PORT=11030
CLOUDFLARE_ACCESS_REQUIRED=true

# Cloudflare Tunnel settings. The token is a secret from the Zero Trust dashboard.
CLOUDFLARED_IMAGE=cloudflare/cloudflared:latest
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARED_METRICS=0.0.0.0:20241
CLOUDFLARED_METRICS_PORT=20241

# Speech-to-text settings. Use "faster_whisper" for local transcription, "mock" for local testing, or "disabled".
TRANSCRIPTION_PROVIDER=faster_whisper
MAX_AUDIO_UPLOAD_BYTES=10485760
FASTER_WHISPER_MODEL=base.en
FASTER_WHISPER_DEVICE=cpu
FASTER_WHISPER_COMPUTE_TYPE=int8
FASTER_WHISPER_DOWNLOAD_ROOT=/models/faster-whisper
FASTER_WHISPER_LOCAL_FILES_ONLY=false
FASTER_WHISPER_LANGUAGE=en
FASTER_WHISPER_BEAM_SIZE=5

# Autotask settings. Use "mock" for local testing or "autotask" for live submission.
AUTOTASK_PROVIDER=mock
AUTOTASK_BASE_URL=https://webservices.example.autotask.net/ATServicesRest/V1.0
AUTOTASK_USERNAME=
AUTOTASK_SECRET=
AUTOTASK_API_INTEGRATION_CODE=
AUTOTASK_RESOURCE_ID=
AUTOTASK_ROLE_ID=
AUTOTASK_BILLING_CODE_ID=
AUTOTASK_TIME_ENTRY_TYPE=2
AUTOTASK_IMPERSONATION_RESOURCE_ID=

# Autotask ticket status picklist IDs vary by Autotask tenant and must be configured from your tenant metadata.
AUTOTASK_STATUS_IN_PROGRESS_ID=
AUTOTASK_STATUS_WAITING_CUSTOMER_ID=
AUTOTASK_STATUS_WAITING_PARTS_ID=
AUTOTASK_STATUS_FOLLOW_UP_ID=
AUTOTASK_STATUS_COMPLETE_ID=
