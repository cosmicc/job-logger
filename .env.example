# Copy this file to .env and replace every production secret before deployment.

# Docker PostgreSQL settings.
POSTGRES_DB=job_logger
POSTGRES_USER=job_logger
POSTGRES_PASSWORD=replace-with-a-long-random-database-password

# FastAPI application settings.
APP_ENV=production
# DEV_BUILD=true shows a yellow DEV badge in the authenticated top bar.
DEV_BUILD=false
APP_SECRET_KEY=replace-with-at-least-32-random-characters
APP_USERNAME=admin
APP_PASSWORD=replace-with-a-long-random-app-password
# LOG_DIR is the app-side path. HOST_LOG_DIR is mounted there so app log files are readable
# from the Docker host. Keep this directory private to server operators.
LOG_DIR=/data/logs
HOST_LOG_DIR=/var/log/job-logger
# LOG_LEVEL controls host-mounted app.log verbosity. Allowed: DEBUG, INFO,
# WARNING, ERROR.
LOG_LEVEL=INFO
# Login attempts are JSONL records with sanitized metadata only. Raw submitted
# passwords are never written to these files or shown on /debug.
LOGIN_FAILURE_LOG_PATH=/data/logs/job-logger-login-failures.log
LOGIN_SUCCESS_LOG_PATH=/data/logs/job-logger-login-successes.log
LOGIN_FAILURE_DEBUG_ROWS=200
APP_SESSION_COOKIE_SECURE=true
# Local app session lifetime in hours before users must sign in again.
APP_SESSION_TIMEOUT_HOURS=12
APP_ALLOWED_HOSTS=localhost,127.0.0.1,app,nginx,replace-with-your-cloudflare-public-hostname
CLOUDFLARE_ACCESS_REQUIRED=false

# Passkey/WebAuthn settings. For Cloudflare Tunnel production, set
# WEBAUTHN_ORIGIN to the public HTTPS origin users see in the browser.
WEBAUTHN_RP_NAME=Job Logger
WEBAUTHN_RP_ID=
WEBAUTHN_ORIGIN=

# Nginx reverse proxy settings. Cloudflare Tunnel should route to Nginx, not directly to FastAPI.
# This is the only port you need to set for deployment. It is the host-facing
# Nginx listener for local troubleshooting and for cloudflared's origin URL.
# The compose stack binds this port on host interfaces so a remotely-managed
# tunnel can use the server's LAN/internal IP as the service URL.
NGINX_PUBLIC_PORT=11030
NGINX_CLIENT_MAX_BODY_SIZE=12m
# Applies only to authenticated /debug/restore uploads.
NGINX_RESTORE_MAX_BODY_SIZE=250m

# Cloudflare Tunnel settings. The token is a secret from the Zero Trust dashboard.
# CLOUDFLARE_TUNNEL_TOKEN is required when you include the cloudflared service
# in your compose run. If missing, the connector loops with "Provided Tunnel
# token is not valid." in cloudflared logs and public requests fail with 502.
CLOUDFLARE_TUNNEL_TOKEN=

# Speech-to-text settings. Use "faster_whisper" for local transcription, "mock" for local testing, or "disabled".
TRANSCRIPTION_PROVIDER=faster_whisper
MAX_AUDIO_UPLOAD_BYTES=10485760
# App-side maximum full backup restore upload size, in bytes.
MAX_BACKUP_RESTORE_BYTES=262144000
# Automatic hourly full-database backups are written under /data/logs/backups
# in Docker by default and retained as 6 hourly plus 3 daily files.
AUTOMATIC_BACKUPS_ENABLED=true
AUTOMATIC_BACKUP_DIR=/data/logs/backups
FASTER_WHISPER_MODEL=base.en
FASTER_WHISPER_DEVICE=cpu
FASTER_WHISPER_COMPUTE_TYPE=int8
FASTER_WHISPER_DOWNLOAD_ROOT=/models/faster-whisper
FASTER_WHISPER_LOCAL_FILES_ONLY=false
FASTER_WHISPER_LANGUAGE=en
FASTER_WHISPER_BEAM_SIZE=5
FASTER_WHISPER_CPU_THREADS=8
FASTER_WHISPER_MEMORY_LIMIT=8g
# Set blank to disable the punctuation-formatting prompt.
FASTER_WHISPER_INITIAL_PROMPT=Use normal written punctuation. When spoken punctuation words such as comma, period, question mark, exclamation point, colon, semicolon, dash, or new paragraph are heard, render punctuation marks and paragraph breaks instead of spelling those words.

# AI summary cleanup settings. Set AI_CLEANUP_ENABLED=true only after you are
# comfortable sending summary text to the selected provider.
AI_CLEANUP_ENABLED=false
# Supported values: gemini, grok, ollama, or lm_studio.
# "grok" uses GroqCloud's API. "ollama" and "lm_studio" are queried
# server-side and must point at loopback, Docker host alias, or private LAN URLs.
AI_CLEANUP_PROVIDER=gemini
AI_CLEANUP_TIMEOUT_SECONDS=20
AI_CLEANUP_MAX_INPUT_CHARS=12000
AI_CLEANUP_INSTRUCTIONS=Clean up MSP work-summary notes for an Autotask time entry. Preserve the technical facts, customer impact, ticket context, and any leading Remote or On-Site prefix. Improve grammar, punctuation, capitalization, and readability. Do not invent work, parts, durations, ticket numbers, root causes, customer approvals, or follow-up actions. Return only the cleaned summary text with no markdown, title, explanation, or surrounding quotes.
# Gemini free-tier API settings.
GEMINI_API_KEY=
GEMINI_CLEANUP_MODEL=gemini-3.5-flash
GEMINI_CLEANUP_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# GroqCloud free/start plan API settings. GROK_API_KEY is also accepted as a
# compatibility fallback, but GROQ_API_KEY matches Groq's official docs.
GROQ_API_KEY=
GROQ_CLEANUP_MODEL=llama-3.1-8b-instant
GROQ_CLEANUP_API_BASE_URL=https://api.groq.com/openai/v1
# Optional compatibility spelling for the requested "grok" provider value:
# GROK_API_KEY=
# GROK_CLEANUP_MODEL=
# GROK_CLEANUP_API_BASE_URL=
# Local Ollama cleanup. The Docker Compose default points at the host machine.
# Use http://127.0.0.1:11434/api only when the app itself is not containerized,
# or use a private LAN base URL such as http://172.25.1.99:11434/api.
# Public URLs are rejected.
OLLAMA_CLEANUP_MODEL=llama3.1
OLLAMA_CLEANUP_API_BASE_URL=http://host.docker.internal:11434/api
# Local LM Studio cleanup through its OpenAI-compatible server. Set the model
# value to the identifier shown by LM Studio for the loaded model. Use a private
# LAN base URL such as http://172.25.1.99:1234/v1 when LM Studio runs elsewhere.
# Public URLs are rejected.
LM_STUDIO_CLEANUP_MODEL=local-model
LM_STUDIO_CLEANUP_API_BASE_URL=http://host.docker.internal:1234/v1
# Optional only if the local LM Studio server requires an API key.
LM_STUDIO_API_KEY=

# Autotask settings. Production requires "autotask"; "mock" is only for tests or isolated development.
# Autotask resource IDs are configured per managed web user in the /users page.
AUTOTASK_PROVIDER=autotask
AUTOTASK_BASE_URL=https://webservices.example.autotask.net/ATServicesRest/V1.0
AUTOTASK_USERNAME=
AUTOTASK_SECRET=
AUTOTASK_API_INTEGRATION_CODE=
AUTOTASK_TIME_ENTRY_TYPE=2

# Optional. Leave false when the API user can create/edit TimeEntries but cannot update Tickets.status.

# Autotask ticket status picklist IDs vary by Autotask tenant. They are needed only when ticket status updates are enabled.
AUTOTASK_STATUS_IN_PROGRESS_ID=
AUTOTASK_STATUS_WAITING_CUSTOMER_ID=
AUTOTASK_STATUS_WAITING_PARTS_ID=
AUTOTASK_STATUS_FOLLOW_UP_ID=
AUTOTASK_STATUS_COMPLETE_ID=
